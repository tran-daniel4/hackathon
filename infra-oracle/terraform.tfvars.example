tenancy_ocid        = "ocid1.tenancy.oc1..aaaaaaa..."
user_ocid           = "ocid1.user.oc1..aaaaaaa..."
fingerprint         = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path    = "~/.oci/oci_api_key.pem"
