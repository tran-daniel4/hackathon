NEXT_PUBLIC_API_URL="http://localhost:8000"
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
NEXTAUTH_SECRET=generated_secret_key
NEXTAUTH_URL="http://localhost:3000"
# Used by the API container (service name resolves inside Docker network)
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/dynodocs"

# Used by Alembic CLI running on your host machine (localhost resolves outside Docker)
ALEMBIC_DATABASE_URL="postgresql+asyncpg://user:password@127.0.0.1:5432/dynodocs"

REDIS_URL="redis://localhost:6379/0"

# JWT — generate a secret with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db